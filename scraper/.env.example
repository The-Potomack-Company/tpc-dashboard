# Supabase admin-client env vars. NEVER commit a real .env — only .env.example.
# The values below are placeholders; populate scraper/.env locally (gitignored).
#
# Service-role key from Supabase Dashboard -> Settings -> API -> service_role.
# This key bypasses RLS. NEVER expose it in the frontend bundle or any VITE_* var.

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<paste-service-role-key-here>
