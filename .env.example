# Supabase connection (same project as TPC App)
#
# Copy this file to .env.local and fill in real values. .env.local is
# git-ignored and must NEVER be committed.

# Public Supabase URL. Safe to expose in the browser bundle.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# VITE_-prefixed vars are auto-injected into the browser bundle by Vite.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — used ONLY by scripts/import-pdfs.ts and the Phase 10
# scraper. It bypasses RLS, so leaking it would let anyone write to any
# table in this project.
#
# WARNINGS:
#   * NEVER prefix this with VITE_ (Vite would inject it into the
#     browser bundle, exposing it to every visitor).
#   * NEVER commit .env.local to git.
#   * Where to find it: Supabase dashboard -> Project Settings -> API ->
#     copy the value labelled "service_role" (NOT "anon").
#   * If it ever leaks, rotate it immediately in the same dashboard page.
SUPABASE_SERVICE_ROLE_KEY=<paste-service-role-secret-here>
