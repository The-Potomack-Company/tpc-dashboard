{
  "name": "tpc-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/check-no-service-role-in-src.mjs && node scripts/verify-extension-app-source-scope.mjs && node scripts/verify-activity-rpc-shape.mjs && node scripts/verify-activity-app-source-scope.mjs && node scripts/verify-activity-bucket-tz.mjs && node scripts/verify-activity-stuck-threshold-hardcoded.mjs && node scripts/verify-activity-mode-filter-on-sessions.mjs && node scripts/verify-activity-table-readonly.mjs && node scripts/verify-activity-photos-ttl.mjs && node scripts/verify-activity-filter-scope.mjs && node scripts/verify-activity-error-state-contract.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest --run",
    "test:e2e": "playwright test",
    "preview": "vite preview",
    "db:push": "supabase db push",
    "db:types": "supabase gen types --lang=typescript --schema public --linked > src/db/database.types.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.101.1",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-table": "^8.21.3",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "googleapis": "^171.4.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.13.1",
    "recharts": "^3.8.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query-devtools": "^5.99.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "supabase": "^2.81.3",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
